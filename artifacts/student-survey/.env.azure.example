# Azure deployment environment variables
# Copy relevant values into GitHub repository settings:
#   Settings → Secrets and variables → Actions

# --- GitHub Actions Secrets ---
# AZURE_STATIC_WEB_APPS_API_TOKEN
#   Found in Azure Portal → your Static Web App → Manage deployment token

# --- GitHub Actions Variables (non-secret) ---
# VITE_API_URL
#   Base URL of your deployed Express API server.
#   Leave empty if the API is served from the same origin via a linked backend.
#   Example (Azure App Service):  https://student-survey-api.azurewebsites.net
#   Example (same-origin linked): (leave blank)
VITE_API_URL=
